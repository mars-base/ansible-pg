---

# NOTE:
# 测试部署，单节点 patroni postgres 集群
# 采用pgbouncer 代理连接池
# 不启用复制
# 不使用haproxy读写分离模式
# 使用 pgbackrest 备份恢复
# NOTE: 本文件为示例，请将 CHANGEME 替换为实际密码后复制为 pg_all.yaml 使用

# ----------------------------------------------
# 定义 patroni postgres 集群的所有节点的配置变量

# 节点角色定义
pg_node_role:
  pg-single:
    roles:
      - etcd
      - patroni
      - pgbouncer
      - pgbackrest
      - cron
      - postgrest
  pg-backup:
    roles:
      - pgbackrest

# haproxy 配置，作为 postgres 数据库集群的负载均衡器，连接到 pgbouncer 代理，读写分离模式
# 读写分离模式：写操作只连接到主节点，读操作连接到从节点
# ha_proxy_list: []
# ha_patroni_postgres_list:
#   - name: pg-patroni-01
#     addr: 192.168.1.11:5433 # through pgbouncer proxy
#   - name: pg-patroni-02
#     addr: 192.168.1.12:5433 # through pgbouncer proxy

# etcd 集群节点定义
etcds_cluster_hosts:
  - name: "pg-single"
    ip:   "{{ansible_default_ipv4.address}}"
    num: 1  # 当前主机上节点编号
etcds_child_count: 1  # 几个节点
etcds_port_roof_client: 12379  # 客户端访问端口
etcds_dir: "/srv/etcds"

# 配置postgresql数据库管理用户
postgres_admin: postgres
postgres_admin_password: CHANGEME
postgres_dba_username: dba
postgres_dba_password: CHANGEME
postgres_readonly_username: ro
postgres_readonly_password: CHANGEME

# pgbouncer 配置，作为 postgres 数据库节点上的sidecar代理连接池
pgbouncer_dir: /srv/pgbouncer
pgbouncer_listen_addr: "{{ ansible_default_ipv4.address }}"
pgbouncer_listen_port: 5433 # pgbouncer 监听端口，在patroni配置中配置启用代理连接池
pgbouncer_socket_dir: "{{ pgbouncer_dir }}" # pgbouncer 代理socket目录
pgbouncer_pool_mode: transaction # 连接池模式，transaction 事务模式，session 会话模式
pgbouncer_users:
  - name: "{{ postgres_admin }}" # postgres 超级用户，用于管理数据库
    password: "{{ postgres_admin_password }}"
  - name: "{{ postgres_dba_username }}"
    password: "{{ postgres_dba_password }}"
  - name: "{{ postgres_readonly_username }}"
    password: "{{ postgres_readonly_password }}"
pgbouncer_databases:
  - name: postgres # postgres 管理数据库
    host: "{{ ansible_default_ipv4.address }}"
    port: 5432
    dbname: postgres
  - name: dev
    host: "{{ ansible_default_ipv4.address }}"
    port: 5432
    dbname: dev
  - name: prod
    host: "{{ ansible_default_ipv4.address }}"
    port: 5432
    dbname: prod
  - name: shard1 # 分片数据库1 用于测试pgdog代理分片功能
    host: "{{ ansible_default_ipv4.address }}"
    port: 5432
    dbname: shard1
  - name: shard2 # 分片数据库2 用于测试pgdog代理分片功能
    host: "{{ ansible_default_ipv4.address }}"
    port: 5432
    dbname: shard2
  - name: jfs
    host: "{{ ansible_default_ipv4.address }}"
    port: 5432
    dbname: jfs
  - name: aifs
    host: "{{ ansible_default_ipv4.address }}"
    port: 5432
    dbname: aifs

# pgbackrest 配置，作为 postgresql 数据库的备份恢复工具
pgbackrest_user: "{{ postgres_admin }}"  # pgbackrest运行用户，保持和patroni里运行postgres用户一致,默认是postgres
pgbackrest_backup_pgpass: "{{ postgres_admin_password }}" # postgres管理员用户的密码，保持和patroni里postgres管理员用户密码一致
pgbackrest_socket_dir: "{{ pgbouncer_socket_dir }}" # pgbouncer代理socket目录
pgbackrest_pg_port: 5433  # pgbouncer代理端口，和pgbouncer监听端口一致
pgbackrest_backup_dir: /srv/pgbackrest_single
pgbackrest_backup_log_dir: /srv/pgbackrest_single/logs
pgbackrest_backup_server: pg-single # 指定备份服务器（单机模式下 PG 和备份在同一台机器）
pgbackrest_stanza: pg-single  # 设置pg集群的备份仓库名称

# pgbackrest ssh 密钥对（备份服务器与 patroni 节点之间通过 ssh 通信）
# 生成方式：ssh-keygen -t rsa -b 4096 -f id_rsa_pgbackrest -N '' -C 'pgbackrest'
pgbackrest_ssh_private_key: |
  -----BEGIN OPENSSH PRIVATE KEY-----
  YOUR_PRIVATE_KEY_CONTENT_HERE
  -----END OPENSSH PRIVATE KEY-----
pgbackrest_ssh_public_key: "YOUR_PUBLIC_KEY_CONTENT_HERE"

# pgbackrest 单机模式配置（PG 和备份在同一台机器，无需 SSH）
pgbackrest_backup_config: |
  [global]
  repo1-path={{ pgbackrest_backup_dir }}
  repo1-retention-full=7
  repo1-retention-full-type=time

  process-max=2
  archive-check=y
  start-fast=y

  log-level-console=info
  log-path={{ pgbackrest_backup_log_dir }}
  log-level-file=debug

  [pg-single]
  pg1-path=/srv/patroni/postgres/data
  pg1-port={{ pgbackrest_pg_port }}
  pg1-socket-path={{ pgbackrest_socket_dir }}
  pg1-database=postgres

pgbackrest_patroni_config: |
  [global]
  repo1-path={{ pgbackrest_backup_dir }}
  repo1-retention-full=7
  repo1-retention-full-type=time

  process-max=2
  archive-check=y
  start-fast=y

  log-level-console=info
  log-path={{ pgbackrest_backup_log_dir }}
  log-level-file=debug

  [{{ pgbackrest_stanza }}]
  pg1-path=/srv/patroni/postgres/data
  pg1-port={{ pgbackrest_pg_port }}
  pg1-socket-path={{ pgbackrest_socket_dir }}
  pg1-database=postgres

# postgrest JWT secret（至少 32 字符）
postgrest_password: "{{ postgres_dba_password }}"
postgrest_jwt_secret: "CHANGEME_CHANGEME_CHANGEME_CHANGEME"

# patroni 配置，作为 postgresql 数据库节点的高可用管理工具
patroni_etcd_address: "{{ ansible_default_ipv4.address }}:12379"
patroni_cluster_name: "pg-single"
patroni_dir: "/srv/patroni"

postgres_version: 17
postgres_replication_username: "replicator"
postgres_replication_password: "CHANGEME"
postgres_superuser_username: "{{ postgres_admin }}"
postgres_superuser_password: "{{ postgres_admin_password }}"
postgres_rewind_username: "rewind"
postgres_rewind_password: "CHANGEME"
postgres_data_dir: "{{ patroni_dir }}/postgres/data"
postgres_replication_trust_cidr: "{{ ansible_default_ipv4.address }}/24"
postgres_archive_command: "pgbackrest --stanza={{ pgbackrest_stanza }} archive-push %p"
postgres_restore_command: "pgbackrest --stanza={{ pgbackrest_stanza }} archive-get %f %p"

postgres_users:
  - name: "{{ postgres_dba_username }}"
    password: "{{ postgres_dba_password }}"
  - name: "{{ postgres_readonly_username }}"
    password: "{{ postgres_readonly_password }}"
postgres_dbs:
  - dev
  - prod
  - shard1 # 分片数据库1 用于测试pgdog代理分片功能
  - shard2 # 分片数据库2 用于测试pgdog代理分片功能
  - jfs
  - aifs
postgres_privs:
  - db: dev
    user: "{{ postgres_dba_username }}"
    type: database
    priv: ALL
    schema: public
    schema_priv: CREATE,USAGE
  - db: prod
    user: "{{ postgres_dba_username }}"
    type: database
    priv: ALL
    schema: public
    schema_priv: CREATE,USAGE
  - db: jfs
    user: "{{ postgres_dba_username }}"
    type: database
    priv: ALL
    schema: public
    schema_priv: CREATE,USAGE
  - db: aifs
    user: "{{ postgres_dba_username }}"
    type: database
    priv: ALL
    schema: public
    schema_priv: CREATE,USAGE
  - db: dev
    user: "{{ postgres_readonly_username }}"
    type: table
    priv: SELECT
    schema: public
    auto_inherit: true
    table_creator: "{{ postgres_dba_username }}"
  - db: prod
    user: "{{ postgres_readonly_username }}"
    type: table
    priv: SELECT
    schema: public
    auto_inherit: true
    table_creator: "{{ postgres_dba_username }}"
  - db: shard1
    user: "{{ postgres_dba_username }}"
    type: database
    priv: ALL
    schema: public
    schema_priv: CREATE,USAGE
  - db: shard2
    user: "{{ postgres_dba_username }}"
    type: database
    priv: ALL
    schema: public
    schema_priv: CREATE,USAGE
  # 配置pgmq扩展 需要的权限
  - db: dev
    user: "{{ postgres_dba_username }}"
    type: database
    priv: ALL
    schema: pgmq
    schema_priv: CREATE,USAGE
  - db: dev
    user: "{{ postgres_dba_username }}"
    type: table
    priv: SELECT,INSERT,UPDATE,DELETE
    schema: pgmq
    auto_inherit: true
    table_creator: "{{ postgres_admin }}"
  - db: prod
    user: "{{ postgres_dba_username }}"
    type: database
    priv: ALL
    schema: pgmq
    schema_priv: CREATE,USAGE
  - db: prod
    user: "{{ postgres_dba_username }}"
    type: table
    priv: SELECT,INSERT,UPDATE,DELETE
    schema: pgmq
    auto_inherit: true
    table_creator: "{{ postgres_admin }}"

# 配置postgresql数据库扩展
# pig_tool: "https://repo.pigsty.io/pkg/pig/v1.0.0/pig_1.0.0-1_amd64.deb"
postgres_shared_preload_libraries: "pg_cron,pg_stat_statements,uuid-ossp"
pg_extensions:
  - "pg_cron"
  - "uuid-ossp"
  - "pg_stat_statements"
  - "pgmq"
pg_create_extensions: false
pg_extensions_on:
  - { db: 'dev', extension: 'pg_stat_statements' }
  - { db: 'prod', extension: 'pg_stat_statements' }
  - { db: 'postgres', extension: 'pg_cron' } # pg_cron固定配置到postgres数据库
  - { db: 'postgres', extension: 'pg_cron' }
  - { db: 'dev', extension: 'uuid-ossp' }
  - { db: 'prod', extension: 'uuid-ossp' }
  - { db: 'dev', extension: 'pgmq' }
  - { db: 'prod', extension: 'pgmq' }
